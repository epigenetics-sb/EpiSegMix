/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running minimal tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Defines input files and everything required to run a fast and simple pipeline test.

    Use as follows:
        nextflow run . -profile test,<docker/singularity> --outdir <OUTDIR>
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

process {
    resourceLimits = [
        cpus: 2,
        memory: '6.GB',
        time: '1.h'
    ]
}

params {
    config_profile_name        = 'Test profile'
    config_profile_description = 'Minimal test dataset to check pipeline function'

    // --- Input & Output ---
    input                      = "${projectDir}/assets/samplesheet.csv"
    outdir                     = 'results'

    // --- Genome & Reference ---
    genome                     = 'mm10'

    // --- Pipeline parameters (Test optimized) ---
    // Note: We use 10000bp bins, 1 state, and 5 iters for speed in testing
    binsize                    = 10000 
    merge                      = true
    states                     = 2
    chr_parameter_estimation   = 1
    iter                       = 5
    
    // --- Model Parameters (Defaults) ---
    dist_histone               = 'NBI'
    dist_methyl                = 'BI'
    adjustment                 = 2
    epsilon                    = 1
    decoding                   = 'viterbi'
    standard                   = false
    fitting                    = false
    duration                   = false
    dna                        = false
    best_fit_segmentation      = false
    episegmix_mode             = 'standard'
    distributions              = 'NBI,SI,BNB'
}
